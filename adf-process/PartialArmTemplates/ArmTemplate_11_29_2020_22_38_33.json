{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-process"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "[concat(parameters('factoryName'), '/CopyExcelToParquet')]",
			"type": "Microsoft.DataFactory/factories/pipelines",
			"apiVersion": "2018-06-01",
			"properties": {
				"activities": [
					{
						"name": "Copy_6lu",
						"type": "Copy",
						"dependsOn": [],
						"policy": {
							"timeout": "7.00:00:00",
							"retry": 0,
							"retryIntervalInSeconds": 30,
							"secureOutput": false,
							"secureInput": false
						},
						"userProperties": [
							{
								"name": "Source",
								"value": "raw/dataset-01/test_data.xlsx"
							},
							{
								"name": "Destination",
								"value": "processed/dataset-01/"
							}
						],
						"typeProperties": {
							"source": {
								"type": "ExcelSource",
								"storeSettings": {
									"type": "AzureBlobFSReadSettings",
									"recursive": true
								}
							},
							"sink": {
								"type": "ParquetSink",
								"storeSettings": {
									"type": "AzureBlobFSWriteSettings"
								},
								"formatSettings": {
									"type": "ParquetWriteSettings"
								}
							},
							"enableStaging": false,
							"enableSkipIncompatibleRow": true,
							"validateDataConsistency": true,
							"logSettings": {
								"enableCopyActivityLog": true,
								"copyActivityLogSettings": {
									"logLevel": "Warning",
									"enableReliableLogging": false
								},
								"logLocationSettings": {
									"linkedServiceName": {
										"referenceName": "RawDataLakeStorage",
										"type": "LinkedServiceReference"
									},
									"path": "logs"
								}
							}
						},
						"inputs": [
							{
								"referenceName": "SourceDataset_6lu",
								"type": "DatasetReference"
							}
						],
						"outputs": [
							{
								"referenceName": "DestinationDataset_6lu",
								"type": "DatasetReference"
							}
						]
					}
				],
				"annotations": []
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/datasets/SourceDataset_6lu')]",
				"[concat(variables('factoryId'), '/datasets/DestinationDataset_6lu')]"
			]
		},
		{
			"name": "[concat(parameters('factoryName'), '/DestinationDataset_6lu')]",
			"type": "Microsoft.DataFactory/factories/datasets",
			"apiVersion": "2018-06-01",
			"properties": {
				"linkedServiceName": {
					"referenceName": "RawDataLakeStorage",
					"type": "LinkedServiceReference"
				},
				"annotations": [],
				"type": "Parquet",
				"typeProperties": {
					"location": {
						"type": "AzureBlobFSLocation",
						"folderPath": "dataset-01",
						"fileSystem": "processed"
					},
					"compressionCodec": "snappy"
				},
				"schema": []
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/SourceDataset_6lu')]",
			"type": "Microsoft.DataFactory/factories/datasets",
			"apiVersion": "2018-06-01",
			"properties": {
				"linkedServiceName": {
					"referenceName": "RawDataLakeStorage",
					"type": "LinkedServiceReference"
				},
				"annotations": [],
				"type": "Excel",
				"typeProperties": {
					"sheetName": "Sheet1",
					"location": {
						"type": "AzureBlobFSLocation",
						"fileName": "test_data.xlsx",
						"folderPath": "dataset-01",
						"fileSystem": "raw"
					},
					"firstRowAsHeader": true
				},
				"schema": [
					{
						"name": "pii_name",
						"type": "String"
					},
					{
						"name": "pii_email",
						"type": "String"
					},
					{
						"name": "pii_mobile",
						"type": "String"
					},
					{
						"name": "attribute1",
						"type": "String"
					},
					{
						"name": "attribute2",
						"type": "String"
					},
					{
						"name": "attribute3",
						"type": "String"
					},
					{
						"name": "attribute4",
						"type": "String"
					},
					{
						"name": "attribute5",
						"type": "String"
					},
					{
						"name": "attribute6",
						"type": "String"
					},
					{
						"name": "attribute7",
						"type": "String"
					}
				]
			},
			"dependsOn": []
		}
	]
}