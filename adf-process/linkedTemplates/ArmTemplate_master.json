{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-process"
		},
		"AzureSynapseAnalytics1_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'AzureSynapseAnalytics1'"
		},
		"RawDataBlobStorage_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'RawDataBlobStorage'"
		},
		"RawDataLakeStorage_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'RawDataLakeStorage'"
		},
		"RawDataLakeStorage_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://demogentingrawdatastore.dfs.core.windows.net"
		},
		"triggerOnFileUploadDataSet-01_properties_typeProperties_scope": {
			"type": "string",
			"defaultValue": "/subscriptions/7c1d967f-37f1-4047-bef7-05af9aa80fe2/resourceGroups/genting-rg/providers/Microsoft.Storage/storageAccounts/rawdatablobstg01"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-process_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2018-02-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"AzureSynapseAnalytics1_connectionString": {
						"value": "[parameters('AzureSynapseAnalytics1_connectionString')]"
					},
					"RawDataBlobStorage_connectionString": {
						"value": "[parameters('RawDataBlobStorage_connectionString')]"
					},
					"RawDataLakeStorage_accountKey": {
						"value": "[parameters('RawDataLakeStorage_accountKey')]"
					},
					"RawDataLakeStorage_properties_typeProperties_url": {
						"value": "[parameters('RawDataLakeStorage_properties_typeProperties_url')]"
					},
					"triggerOnFileUploadDataSet-01_properties_typeProperties_scope": {
						"value": "[parameters('triggerOnFileUploadDataSet-01_properties_typeProperties_scope')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}